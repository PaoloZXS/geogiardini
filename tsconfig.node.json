{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "composite": true
  },
  "include": ["vite.config.ts", "server.ts", "api/**/*.ts", "lib/**/*.ts"]
}
